    printf '  "arch": "h200"\n' >> /opt/BUILD_INFO.json && \
    printf '}\n' >> /opt/BUILD_INFO.json && \
    cat /opt/BUILD_INFO.json

# ---- Sanity: all imports + SGLang surface area ----
# Reuses customer-h200.5 checks; adds NIXL-side asserts.
RUN python -c "import torch; print('torch', torch.__version__, 'cuda', torch.version.cuda)" && \
    python -c "import mooncake; print('mooncake OK')" && \
    python -c "from mooncake.engine import TransferEngine; print('mooncake.engine.TransferEngine OK')" && \
    python -c "import json; bi = json.load(open('/opt/BUILD_INFO.json')); \
               assert 'pr-2023' in bi.get('mooncake_patches', []), 'pr-2023 not recorded in BUILD_INFO.json'; \
               print('mooncake_patches recorded:', bi['mooncake_patches'])" && \
    test -f /usr/lib/x86_64-linux-gnu/libpython3.10.so.1.0 && echo "libpython3.10.so.1.0 OK" && \
    test -f /usr/include/python3.10/Python.h && echo "Python.h OK" && \
    test -x /usr/bin/ninja && ninja --version && echo "ninja OK" && \
    python -c "import sglang; print('sglang', sglang.__version__)" && \
    python -c "import inspect, sglang.srt.distributed.device_communicators.mooncake_transfer_engine as m; \
               src = inspect.getsource(m); \
               assert '\"efa\",' in src, 'mooncake efa patch missing in runtime image'; \
               assert '\"rdma\",' not in src, 'mooncake rdma token leaked into runtime image'; \
               print('mooncake efa patch OK in runtime')" && \
    python -c "import uccl.ep; print('uccl.ep OK')" && \
    python -c "import deep_ep; m = deep_ep.Config.__module__; \
               assert m.startswith('uccl'), f'deep_ep not uccl-backed: {m}'; \
               print('deep_ep OK (uccl-backed):', m)" && \
    test -x /opt/mooncake/install/bin/transfer_engine_bench && \
    (python -m sglang.launch_server --help 2>&1 | grep -E "disaggregation-transfer-backend" | head -5) && \
    python -m sglang.launch_server --help 2>&1 | grep -E "disaggregation-transfer-backend" | grep -q "mooncake" && \
    python -m sglang.launch_server --help 2>&1 | grep -E "disaggregation-transfer-backend" | grep -q "nixl" && \
    echo "SGLang shows BOTH mooncake and nixl as disaggregation-transfer-backend choices" && \
    ls /opt/nixl/lib/x86_64-linux-gnu/plugins/ && \
    python -c "import importlib, importlib.util; \
               names = ['nixl_cu13', 'nixl_cu12', 'nixl']; \
               mod = next((importlib.import_module(n) for n in names if importlib.util.find_spec(n) is not None), None); \
               assert mod is not None, f'FATAL: none of {names} importable as NIXL python binding'; \
               print(f'NIXL python binding OK: {mod.__name__} @ {mod.__file__}')" && \
    python -c "from nixl._api import nixl_agent, nixl_agent_config; print('nixl._api (SGLang import path) OK')" && \
    echo "=== All sanity checks passed (variant=${VARIANT}) ==="

WORKDIR /workspace
CMD ["/bin/bash"]
