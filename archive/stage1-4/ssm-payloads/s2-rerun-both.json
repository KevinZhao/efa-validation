{"commands":[
  "sudo -iu ec2-user bash -lc 'kubectl -n yanxi-validation delete mpijob uccl-ep-perf-uccl uccl-ep-perf-nccl --ignore-not-found --wait=true 2>&1 || true'",
  "sleep 10",
  "sudo -iu ec2-user bash -lc 'echo  | base64 -d > ~/workspace/yanxi/stage2/mpijob-perf-uccl.yaml && echo  | base64 -d > ~/workspace/yanxi/stage2/mpijob-perf-nccl.yaml'",
  "sudo -iu ec2-user bash -lc 'kubectl apply -f ~/workspace/yanxi/stage2/mpijob-perf-nccl.yaml 2>&1'",
  "sleep 30",
  "sudo -iu ec2-user bash -lc 'kubectl -n yanxi-validation get pods -o wide 2>&1'"
]}
