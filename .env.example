# Copy to .env and fill in before running any script under scripts/.
# Consumed by scripts/lib.sh.

# ---- AWS identifiers ----
AWS_ACCOUNT_ID=123456789012
AWS_REGION_PRIMARY=us-east-2
AWS_REGION_FALLBACK=us-west-2

# ---- EKS clusters ----
OHIO_CLUSTER=<EKS_CLUSTER_NAME_OHIO>
OREGON_CLUSTER=<EKS_CLUSTER_NAME_OREGON>

# ---- EC2 instances (for SSM send-command) ----
OHIO_BASTION=i-0000000000000000a
OREGON_BASTION=i-0000000000000000b
BUILDER_ID=i-0000000000000000c

# ---- ECR + S3 ----
# ECR_REG defaults to ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION_PRIMARY}.amazonaws.com
ECR_REG=
# S3 bucket used for dockerfile/manifest/log distribution
S3_BUCKET=efa-validation-123456789012
