{"commands":[
  "sudo -iu ec2-user bash -lc 'echo  | base64 -d > ~/workspace/eks-cluster-deployment/.env.oregon'",
  "sudo -iu ec2-user bash -lc 'cp -f ~/workspace/eks-cluster-deployment/.env.oregon ~/workspace/eks-cluster-deployment/.env && grep -E \"^(CLUSTER_NAME|AWS_REGION|VPC_ID)\" ~/workspace/eks-cluster-deployment/.env'",
  "sudo -iu ec2-user bash -lc 'aws eks update-kubeconfig --name gpu-cluster-oregon --region us-west-2 --alias oregon 2>&1'",
  "sudo -iu ec2-user bash -lc 'kubectl --context oregon get nodes -o wide 2>&1'",
  "echo --- ns ---",
  "sudo -iu ec2-user bash -lc 'kubectl --context oregon get ns 2>&1'",
  "echo --- nodegroups ---",
  "sudo -iu ec2-user bash -lc 'aws eks list-nodegroups --cluster-name gpu-cluster-oregon --region us-west-2'"
]}
