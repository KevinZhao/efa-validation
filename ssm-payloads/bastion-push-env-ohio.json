{"commands":[
  "sudo -iu ec2-user bash -lc 'echo  | base64 -d > ~/workspace/eks-cluster-deployment/.env.ohio'",
  "sudo -iu ec2-user bash -lc 'cp -f ~/workspace/eks-cluster-deployment/.env.ohio ~/workspace/eks-cluster-deployment/.env && grep -E \"^(CLUSTER_NAME|AWS_REGION|VPC_ID)\" ~/workspace/eks-cluster-deployment/.env'",
  "sudo -iu ec2-user bash -lc 'aws eks update-kubeconfig --name gpu-cluster-ohio --region us-east-2 --alias ohio 2>&1'",
  "sudo -iu ec2-user bash -lc 'kubectl --context ohio get nodes -o wide 2>&1'",
  "echo --- ns ---",
  "sudo -iu ec2-user bash -lc 'kubectl --context ohio get ns 2>&1'",
  "echo --- nodegroups ---",
  "sudo -iu ec2-user bash -lc 'aws eks list-nodegroups --cluster-name gpu-cluster-ohio --region us-east-2'"
]}
